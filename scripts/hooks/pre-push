#!/usr/bin/env bash
# pre-push - gate `git push` on `mise run check` and refresh the `local-check`
# commit status that `master` branch protection requires.
#
# Enable for this clone with:
#   git config core.hooksPath scripts/hooks
#
# Skip with BACKSTAGE_SKIP_LOCAL_CHECK=1.

set -euo pipefail

if [[ "${BACKSTAGE_SKIP_LOCAL_CHECK:-0}" == 1 ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
script="$repo_root/scripts/local-check.sh"
if [[ ! -x "$script" ]]; then
  printf 'pre-push: %s missing or not executable\n' "$script" >&2
  exit 1
fi

zero="0000000000000000000000000000000000000000"
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$zero" ]]; then
    continue
  fi
  BACKSTAGE_LOCAL_CHECK_SHA="$local_sha" "$script" --pre-push
done
